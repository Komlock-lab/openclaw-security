{
  "name": "auditclaw",
  "version": "0.1.0",
  "type": "module",
  "description": "Security scanner for OpenClaw - Detect vulnerabilities and check runtime configuration",
  "author": "natsuki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/natsuki/auditclaw.git"
  },
  "keywords": [
    "openclaw",
    "security",
    "vulnerability",
    "scanner",
    "audit",
    "cve",
    "ghsa"
  ],
  "bin": {
    "auditclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "build-skill": "tsx scripts/build-skill.ts",
    "test": "node --test src/__tests__/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "data"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
